{
  "name": "@vkirill/tencentdb-agent-memory",
  "version": "0.1.0",
  "description": "Four-layer local memory (L0→L1→L2→L3) for Claude Code and other agents — SQLite vector search + OpenAI-compatible LLM/embedding providers. Forked from Tencent/TencentDB-Agent-Memory.",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "claude-mem": "./bin/claude-mem.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:gate": "bash scripts/check-no-openclaw.sh"
  },
  "files": [
    "dist/",
    "bin/",
    "index.ts",
    "src/",
    "templates/",
    "claude-code-integration/",
    "README.md",
    "CHANGELOG.md",
    "NOTICE.md",
    "LICENSE",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/__tests__/",
    "!src/__smoke__/"
  ],
  "keywords": [
    "memory",
    "ai-memory",
    "long-term-memory",
    "vector-search",
    "sqlite-vec",
    "llm",
    "openrouter",
    "voyage-ai",
    "claude-code",
    "conversation",
    "persona",
    "scene-extraction",
    "embedding"
  ],
  "author": "VKirill",
  "license": "MIT",
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@node-rs/jieba": "^2.0.1",
    "@tencentdb-agent-memory/tcvdb-text": "^0.1.1",
    "ai": "^6.0.164",
    "commander": "^14.0.1",
    "js-tiktoken": "^1.0.18",
    "json5": "^2.2.3",
    "sqlite-vec": "0.1.7-alpha.2",
    "tsx": "^4.21.0",
    "undici": "^8.1.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "opik": "^1.0.0"
  },
  "peerDependencies": {
    "node-llama-cpp": "^3.16.2"
  },
  "peerDependenciesMeta": {
    "node-llama-cpp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
