# claude-mem environment template
# Copy to .env in your project (or export from ~/.bashrc / ~/.zshrc)
# and source/load before invoking `claude`.
#
# v0.1+v0.2 of claude-mem use these only for the LLM/embedding pipeline
# (v0.3 and later). Without keys, capture/recall still work — recall is
# keyword-based and capture writes raw L0 turns. Vector search activates
# in v0.3 when keys are present.

# OpenRouter — LLM provider for L1/L2/L3 extraction. Default model:
# tencent/hy3-preview. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Voyage AI — embeddings provider (voyage-3-lite, 512-d). Free tier
# 200M tokens/mo. Get a key at https://dash.voyageai.com
VOYAGE_API_KEY=

# Optional: log level for memory.log
# CLAUDE_MEM_LOG_LEVEL=info
