# claude-mem environment — sourced by hook wrappers (set -a / . / set +a).
#
# Installed by claude-code-integration/install.sh to ~/.claude/claude-mem.env
# with mode 0600 (owner read/write only). NEVER overwritten on re-install.
#
# Edit this file and add your real API keys. Then start a new Claude Code
# session — hooks will pick them up automatically via the wrapper's
# `set -a; . "$HOME/.claude/claude-mem.env"; set +a` block.
#
# v0.3.0+ uses these when you run `claude-mem extract` (the LLM pipeline).
# Without them, capture/recall still work — they degrade to keyword-only.

# OpenRouter — LLM provider for L1 fact extraction.
# Default model: tencent/hy3-preview. Get a key at:
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Voyage AI — embeddings provider (voyage-3-lite, 512-dim).
# Free tier: 200M tokens/mo. Get a key at:
#   https://dash.voyageai.com
VOYAGE_API_KEY=

# Optional: pipeline log verbosity (debug | info | warn | error).
# CLAUDE_MEM_LOG_LEVEL=info
